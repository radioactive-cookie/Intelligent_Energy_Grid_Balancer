# Backend API base URL.
# For local Vite proxy this should be /api (default in code).
# To bypass proxy and call backend directly:
# VITE_API_URL=http://localhost:10000
VITE_API_URL=/api

# WebSocket URL for live grid updates.
# For local Vite proxy this should be /ws (default in code).
# To bypass proxy and call backend directly:
# VITE_WS_URL=ws://localhost:10000/ws
VITE_WS_URL=/ws

# Production (Vercel frontend + Render backend) examples:
# VITE_API_URL=https://your-render-service.onrender.com
# VITE_WS_URL=wss://your-render-service.onrender.com/ws
# Note: If you use https://... for VITE_WS_URL, the frontend converts it to wss:// automatically.
